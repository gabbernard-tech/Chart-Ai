.decision-box.go { border-color: var(–green); background: linear-gradient(135deg, rgba(0,255,136,0.08), transparent); }
.decision-box.wait { border-color: var(–gold); background: linear-gradient(135deg, rgba(255,209,102,0.08), transparent); }
.decision-box.nogo { border-color: var(–red); background: linear-gradient(135deg, rgba(255,60,95,0.08), transparent); }

.decision-label {
