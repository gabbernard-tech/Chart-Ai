<script>
// API Key Management - stored in browser localStorage only (NEVER on GitHub)
let API_KEY = null;

function loadApiKey() {
  API_KEY = localStorage.getItem('chartai_api_key');
  if (API_KEY) {
    document.getElementById('setupModal').classList.remove('visible');
    document.getElementById('apiStatus').style.display = 'flex';
  } else {
    document.getElementById('setupModal').classList.add('visible');
    document.getElementById('apiStatus').style.display = 'none';
  }
}

function saveApiKey() {
  const key = document.getElementById('apiKeyInput').value.trim();
  if (!key.startsWith('sk-ant-')) {
    alert('La clé doit commencer par sk-ant-');
    return;
  }
  localStorage.setItem('chartai_api_key', key);
  API_KEY = key;
  document.getElementById('apiKeyInput').value = '';
  loadApiKey();
}

function resetApiKey() {
  if (confirm('Supprimer la clé API sauvegardée ?')) {
    localStorage.removeItem('chartai_api_key');
    API_KEY = null;
    loadApiKey();
  }
}

// Initialize
loadApiKey();

let images = { '5min': null, '1min': null };
let mimes = { '5min': 'image/jpeg', '1min': 'image/jpeg' };

['5min', '1min'].forEach(tf => {
  const input = document.getElementById('file' + tf);
  const zone = document.getElementById('zone' + tf);
  const preview = document.getElementById('preview' + tf);

  input.addEventListener('change', e => {
    const file = e.target.files[0];
    if (!file) return;
    mimes[tf] = file.type || 'image/jpeg';
    const reader = new FileReader();
    reader.onload = ev => {
      images[tf] = ev.target.result.split(',')[1];
      preview.src = ev.target.result;
      zone.classList.add('has-image');
      checkReady();
    };
    reader.readAsDataURL(file);
  });
});

function checkReady() {
  document.getElementById('analyzeBtn').disabled = !images['5min'];
}

async function analyzeChart() {
  if (!API_KEY) {
    alert('Configure ta clé API d\'abord !');
    document.getElementById('setupModal').classList.add('visible');
    return;
  }

  if (!images['5min']) return;

  const ticker = document.getElementById('ticker').value.trim() || 'STOCK';
  const budget = parseFloat(document.getElementById('budget').value) || 1000;

  document.getElementById('loading').classList.add('visible');
  document.getElementById('results').classList.remove('visible');
  document.getElementById('errorBox').classList.remove('visible');
  document.getElementById('analyzeBtn').disabled = true;

  const prompt = `Tu es un expert en day trading de penny stocks. Analyse ${images['1min'] ? 'ces deux charts (5min principal et 1min précis)' : 'ce chart 5min'} pour le ticker ${ticker}.

L'utilisateur a un budget de ${budget}$ et fait du DAY TRADING (entrée et sortie le même jour).

Critères d'analyse:
- Position vs VWAP (au-dessus = bullish, en-dessous = bearish)
- Volume vs moyen
- Pattern (bull flag, gap and go, vwap reclaim, breakout, etc.)
- RSI surchauffe (>80 = pullback probable)
- Niveaux intraday (high/low du jour)
- R/R minimum 1:2

Réponds UNIQUEMENT avec un JSON valide, rien d'autre, pas de markdown:
{"decision":"GO ou WAIT ou NOGO","decision_reason":"raison courte 1-2 phrases","confidence":75,"setup_name":"nom du setup","setup_desc":"description","entry_price":"prix exact","stop_price":"prix stop","tp1_price":"target 1","tp2_price":"target 2","positives":["point 1","point 2","point 3"],"warnings":["risque 1","risque 2"]}

Important:
- Stop loss serré (-3 a -8% max)
- TP1 +5-10%, TP2 plus ambitieux
- Setup pas clair = WAIT
- Setup baissier ou risque eleve = NOGO`;

  const content = [
    { type: "image", source: { type: "base64", media_type: mimes['5min'], data: images['5min'] } }
  ];

  if (images['1min']) {
    content.push({ type: "image", source: { type: "base64", media_type: mimes['1min'], data: images['1min'] } });
  }

  content.push({ type: "text", text: prompt });

  try {
    const res = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "x-api-key": API_KEY,
        "anthropic-version": "2023-06-01",
        "anthropic-dangerous-direct-browser-access": "true"
      },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 1500,
        messages: [{ role: "user", content }]
      })
    });

    if (!res.ok) {
      const err = await res.json();
      throw new Error(err.error?.message || "Erreur API " + res.status);
    }

    const data = await res.json();
    const raw = data.content.map(i => i.text || '').join('');
    const start = raw.indexOf('{');
    const end = raw.lastIndexOf('}');
    if (start === -1) throw new Error("Reponse invalide");

    const json = JSON.parse(raw.slice(start, end + 1));
    displayResults(json, budget);

  } catch (err) {
    document.getElementById('errorBox').textContent = "⚠️ " + err.message;
    document.getElementById('errorBox').classList.add('visible');
    console.error(err);
  } finally {
    document.getElementById('loading').classList.remove('visible');
    document.getElementById('analyzeBtn').disabled = false;
  }
}

function displayResults(d, budget) {
  const decisionBox = document.getElementById('decisionBox');
  decisionBox.className = 'decision-box ' + (d.decision === 'GO' ? 'go' : d.decision === 'WAIT' ? 'wait' : 'nogo');
  document.getElementById('decisionValue').textContent = d.decision || '—';
  document.getElementById('decisionReason').textContent = d.decision_reason || '';

  const conf = parseInt(d.confidence) || 50;
  document.getElementById('confidenceFill').style.width = conf + '%';
  document.getElementById('confidenceLabel').textContent = conf + '%';

  document.getElementById('setupValue').textContent = d.setup_name || '—';
  document.getElementById('setupDesc').textContent = d.setup_desc || '';

  const entry = parseFloat(d.entry_price) || 0;
  const stop = parseFloat(d.stop_price) || 0;
  const tp1 = parseFloat(d.tp1_price) || 0;
  const tp2 = parseFloat(d.tp2_price) || 0;

  document.getElementById('entryPrice').textContent = '$' + (d.entry_price || '—');
  document.getElementById('stopPrice').textContent = '$' + (d.stop_price || '—');
  document.getElementById('tp1Price').textContent = '$' + (d.tp1_price || '—');
  document.getElementById('tp2Price').textContent = '$' + (d.tp2_price || '—');

  const shares = entry > 0 ? Math.floor(budget / entry) : 0;
  document.getElementById('sharesValue').textContent = shares + ' actions';

  const riskPerShare = Math.abs(entry - stop);
  const rewardPerShare = Math.abs(tp2 - entry);
  const rr = riskPerShare > 0 ? (rewardPerShare / riskPerShare).toFixed(1) : null;
  const totalRisk = (riskPerShare * shares).toFixed(0);
  const totalProfit = (rewardPerShare * shares).toFixed(0);

  document.getElementById('rrValue').textContent = rr ? '1:' + rr : '—';
  document.getElementById('riskValue').textContent = '-$' + totalRisk;
  document.getElementById('profitValue').textContent = '+$' + totalProfit;

  const posList = document.getElementById('positivesList');
  posList.innerHTML = '';
  (d.positives || []).forEach(p => {
    const li = document.createElement('li');
    li.textContent = p;
    posList.appendChild(li);
  });

  const warnList = document.getElementById('warningsList');
  warnList.innerHTML = '';
  (d.warnings || []).forEach(w => {
    const li = document.createElement('li');
    li.textContent = w;
    warnList.appendChild(li);
  });

  document.getElementById('results').classList.add('visible');
  document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function reset() {
  images = { '5min': null, '1min': null };
  ['5min', '1min'].forEach(tf => {
    document.getElementById('zone' + tf).classList.remove('has-image');
    document.getElementById('preview' + tf).src = '';
    document.getElementById('file' + tf).value = '';
  });
  document.getElementById('ticker').value = '';
  document.getElementById('budget').value = '';
  document.getElementById('results').classList.remove('visible');
  document.getElementById('errorBox').classList.remove('visible');
  document.getElementById('analyzeBtn').disabled = true;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>

