line-height: 1.6;
}

.error-box.visible { display: block; }

.results { display: none; margin-top: 24px; animation: fadeUp 0.4s ease; }
.results.visible { display: block; }

@keyframes fadeUp {
from { opacity: 0; transform: translateY(16px); }
to { opacity: 1; transform: translateY(0); }
}

